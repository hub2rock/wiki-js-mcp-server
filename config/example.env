# wiki-js-mcp-server — Configuration
# Copy this file to .env at the project root and fill in your values.
# Never commit .env to version control.

# ── Wiki.js ───────────────────────────────────────────────────────────────────
WIKIJS_URL=https://your-wiki.example.com
WIKIJS_API_KEY=your_api_key_here
WIKIJS_GRAPHQL_ENDPOINT=/graphql

# ── Transport ─────────────────────────────────────────────────────────────────
# stdio  → Claude Desktop local (process spawned directly)
# http   → Docker remote (server listens on HTTP/SSE)
MCP_TRANSPORT=stdio

# HTTP mode (only used when MCP_TRANSPORT=http)
HTTP_HOST=0.0.0.0
HTTP_PORT=8000

# ── Storage ───────────────────────────────────────────────────────────────────
# ⚠️  Use absolute paths in stdio mode — Claude Desktop launches from /
# Example: /Users/yourname/tools/wiki-js-mcp-server/wikijs_mappings.db
WIKIJS_MCP_DB=./wikijs_mappings.db
LOG_FILE=./wikijs_mcp.log

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DEFAULT_SPACE_NAME=Documentation
